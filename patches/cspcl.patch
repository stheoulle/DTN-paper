diff --git a/src/cspcl.c b/src/cspcl.c
index 77d9666..6c9d8f9 100644
--- a/src/cspcl.c
+++ b/src/cspcl.c
@@ -140,7 +140,7 @@ static csp_conn_t *cspcl_pool_get_or_create_locked(cspcl_conn_pool_t *pool, uint
     pool->stats.evictions++;
   }
 
-  csp_conn_t *conn = csp_connect(CSP_PRIO_NORM, dest_addr, dest_port, CSPCL_CSP_TIMEOUT_MS,
+  csp_conn_t *conn = csp_connect(CSP_PRIO_NORM, dest_addr, dest_port, CSPCL_CSP_CONNECT_TIMEOUT_MS,
                                  CSPCL_CSP_CONN_OPTIONS);
   if (conn == NULL) {
     pool->stats.connect_failures++;
@@ -453,9 +453,10 @@ cspcl_error_t cspcl_send_bundle(cspcl_t *cspcl, const uint8_t *bundle, size_t le
   /* Use CSP's SFP to send the bundle with automatic fragmentation */
   int ret = csp_sfp_send(conn, bundle, (unsigned int) len, CSPCL_MAX_PAYLOAD, CSPCL_CSP_TIMEOUT_MS);
 
-  if (ret != CSP_ERR_NONE) {
-    cspcl_pool_invalidate_locked(pool, dest_addr, dest_port);
-  }
+  /* Always invalidate: with RDP the receiver closes the connection after
+   * delivery, so any cached conn is stale by the next send.  Reusing a
+   * remotely-closed RDP connection corrupts libcsp internal state. */
+  cspcl_pool_invalidate_locked(pool, dest_addr, dest_port);
 
   if (cspcl_pool_unlock(pool) != 0) {
     CSPCL_LOG("pool unlock failed after send");
diff --git a/src/cspcl_config.h b/src/cspcl_config.h
index 0b940a6..8539c79 100644
--- a/src/cspcl_config.h
+++ b/src/cspcl_config.h
@@ -33,11 +33,19 @@
 #define CSPCL_PORT_BP 10
 #endif
 
-/** CSP connection timeout in milliseconds */
+/** CSP timeout (ms) for SFP fragment sends and csp_accept */
 #ifndef CSPCL_CSP_TIMEOUT_MS
 #define CSPCL_CSP_TIMEOUT_MS 1000
 #endif
 
+/** CSP timeout (ms) per RDP SYN retransmission attempt in csp_connect.
+ *  CSP RDP retries ~10 times, so the total failure window is
+ *  CSPCL_CSP_CONNECT_TIMEOUT_MS * ~10.  Keep this well under any caller's
+ *  PDU watchdog (unibo-bp fires at ~10 s, so stay under ~1 s total). */
+#ifndef CSPCL_CSP_CONNECT_TIMEOUT_MS
+#define CSPCL_CSP_CONNECT_TIMEOUT_MS 100
+#endif
+
 /** CSP connection options for outbound connections (bitmask of CSP_O_*) */
 #ifndef CSPCL_CSP_CONN_OPTIONS
 #define CSPCL_CSP_CONN_OPTIONS CSP_O_RDP
