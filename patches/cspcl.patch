  @@ -33,11 +33,19 @@
  -/** CSP connection timeout in milliseconds */
  +/** CSP timeout (ms) for SFP fragment sends and csp_accept */
   #ifndef CSPCL_CSP_TIMEOUT_MS
   #define CSPCL_CSP_TIMEOUT_MS 1000
   #endif
   
  +/** CSP timeout (ms) per RDP SYN retransmission attempt in csp_connect.
  + *  CSP RDP retries ~10 times, so the total failure window is
  + *  CSPCL_CSP_CONNECT_TIMEOUT_MS * ~10.  Keep this well under any caller's
  + *  PDU watchdog (unibo-bp fires at ~10 s, so stay under ~1 s total). */
  +#ifndef CSPCL_CSP_CONNECT_TIMEOUT_MS
  +#define CSPCL_CSP_CONNECT_TIMEOUT_MS 100
  +#endif
