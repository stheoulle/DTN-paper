  +  /* Wait up to 5 s for the ACK.  In BDM mode the ACK only arrives after
  +   * asabr_bdm dispatches the bundle, so this can take a moment. */
  +  struct timeval tv = { .tv_sec = 5, .tv_usec = 0 };
  +  setsockopt(client->socket_fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
  +
  +  uint64_t msg_size;
  +  if (recv_varint(client->socket_fd, &msg_size) < 0) {
  +    log_warn("Bundle ACK not received within timeout — bundle is in flight");
  +    tv.tv_sec = 0; tv.tv_usec = 0;
  +    setsockopt(client->socket_fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
  +    return 0;
  +  }
  +
  +  /* Reset to blocking for future use */
  +  tv.tv_sec = 0; tv.tv_usec = 0;
  +  setsockopt(client->socket_fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
  +
  +  uint8_t *ack = malloc(msg_size);
  +  if (!ack || recv_exact(client->socket_fd, ack, msg_size) < 0) {
  +    log_error("Couldn't receive bundle ACK body");
  +    free(ack);
  +    return -1;
  +  }
  +  if (handle_aap2_response(ack, msg_size) < 0) {
  +    log_error("Bundle was rejected by BPA");
  +    return -1;
  +  }
  +
  +  return 0;
