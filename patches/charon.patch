diff --git a/src/aap2_client.c b/src/aap2_client.c
index 72f7bd9..751b5bc 100644
--- a/src/aap2_client.c
+++ b/src/aap2_client.c
@@ -322,6 +322,12 @@ int handle_aap2_response(uint8_t *message, uint64_t msg_size) {
   Aap2__AAPResponse *aap2_response =
       aap2__aapresponse__unpack(NULL, msg_size, message);
 
+  if (!aap2_response) {
+    log_error("Failed to unpack AAPResponse");
+    free(message);
+    return -1;
+  }
+
   log_info("%i", aap2_response->response_status);
 
   switch (aap2_response->response_status) {
@@ -416,11 +422,39 @@ int send_aap2(aap2_client *client, const char *dst_eid, uint8_t *payload,
     return -1;
   }
 
-  log_info("Configuration sent !");
+  log_info("Bundle sent !");
   free(buf);
   free(eid);
 
-  return -1;
+  /* Wait up to 5 s for the ACK.  In BDM mode the ACK only arrives after
+   * asabr_bdm dispatches the bundle, so this can take a moment. */
+  struct timeval tv = { .tv_sec = 5, .tv_usec = 0 };
+  setsockopt(client->socket_fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
+
+  uint64_t msg_size;
+  if (recv_varint(client->socket_fd, &msg_size) < 0) {
+    log_warn("Bundle ACK not received within timeout — bundle is in flight");
+    tv.tv_sec = 0; tv.tv_usec = 0;
+    setsockopt(client->socket_fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
+    return 0;
+  }
+
+  /* Reset to blocking for future use */
+  tv.tv_sec = 0; tv.tv_usec = 0;
+  setsockopt(client->socket_fd, SOL_SOCKET, SO_RCVTIMEO, &tv, sizeof(tv));
+
+  uint8_t *ack = malloc(msg_size);
+  if (!ack || recv_exact(client->socket_fd, ack, msg_size) < 0) {
+    log_error("Couldn't receive bundle ACK body");
+    free(ack);
+    return -1;
+  }
+  if (handle_aap2_response(ack, msg_size) < 0) {
+    log_error("Bundle was rejected by BPA");
+    return -1;
+  }
+
+  return 0;
 }
 
